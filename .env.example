# Telegram Bot Token (lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID của các admin (phân cách bằng dấu phẩy)
ADMIN_IDS=123456789,987654321

# API key từ football-data.org (đăng ký miễn phí)
FOOTBALL_API_KEY=your_api_key_here

# Các giải đấu theo dõi (phân cách bằng dấu phẩy)
# PL=Premier League, CL=Champions League, WC=World Cup
# PD=La Liga, BL1=Bundesliga, SA=Serie A, FL1=Ligue 1
WATCHED_COMPETITIONS=PL,CL

# Đường dẫn database
DB_PATH=football_bot.db
